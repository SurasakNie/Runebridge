{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","additionalProperties":false,"required":["task_id","reviewer","verdict","blockers","scope_drift"],"properties":{"task_id":{"type":"string","pattern":"^[A-Za-z0-9._-]+$"},"reviewer":{"enum":["qwen","claude"]},"verdict":{"enum":["approve","changes_requested","reject"]},"blockers":{"type":"array","items":{"type":"string"}},"bugs_found":{"type":"array","items":{"type":"string"}},"missing_tests":{"type":"array","items":{"type":"string"}},"scope_drift":{"type":"boolean"},"drift_detail":{"type":"string"},"security_concerns":{"type":"array","items":{"type":"string"}},"suggestions":{"type":"array","items":{"type":"string"}},"risk_assessment":{"enum":["RSK-0","RSK-1","RSK-2"]},"human_review_required":{"type":"boolean"},"notes":{"type":"array","items":{"type":"string"}}},"allOf":[{"if":{"properties":{"reviewer":{"const":"qwen"}}},"then":{"required":["bugs_found","missing_tests","security_concerns","suggestions"]}},{"if":{"properties":{"reviewer":{"const":"claude"}}},"then":{"required":["risk_assessment","human_review_required","notes"]}}]}
