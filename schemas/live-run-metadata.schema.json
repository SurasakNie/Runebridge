{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "vendor",
    "role",
    "execution",
    "cli_name",
    "cli_version",
    "model_identifier",
    "authentication_class",
    "credentials_available",
    "approval_id_sha256",
    "exit_code",
    "attempt_count",
    "timeout_seconds",
    "budget_ceiling_usd",
    "budget_result",
    "blocked_command_count",
    "schema_valid",
    "scope_valid",
    "secret_scan_passed",
    "result_sha256",
    "run_date"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9._-]+$"
    },
    "vendor": {
      "enum": ["claude", "codex", "qwen", "antigravity"]
    },
    "role": {
      "enum": ["planner", "builder", "reviewer", "verifier"]
    },
    "execution": {
      "const": "live"
    },
    "cli_name": {
      "type": "string",
      "minLength": 1
    },
    "cli_version": {
      "type": "string",
      "minLength": 1
    },
    "model_identifier": {
      "type": ["string", "null"]
    },
    "authentication_class": {
      "enum": ["interactive_session", "environment_secret", "test_fixture"]
    },
    "credentials_available": {
      "type": "boolean"
    },
    "approval_id_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "exit_code": {
      "const": 0
    },
    "attempt_count": {
      "const": 1
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300
    },
    "budget_ceiling_usd": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 10
    },
    "budget_result": {
      "enum": ["not_reported", "within_ceiling"]
    },
    "blocked_command_count": {
      "const": 0
    },
    "schema_valid": {
      "const": true
    },
    "scope_valid": {
      "const": true
    },
    "secret_scan_passed": {
      "const": true
    },
    "result_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "run_date": {
      "type": "string",
      "format": "date"
    }
  }
}
