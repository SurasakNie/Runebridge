# Safe defaults for local dry-run validation.
DRY_RUN_MODE=true
RUNEBRIDGE_MODE=safe-default

# Leave credentials empty in this file. Set real values only in an ignored
# .env file, the current shell environment, or an approved secret manager.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
ANTIGRAVITY_API_KEY=
GITHUB_TOKEN=
RUNEBRIDGE_APP_TOKEN=

